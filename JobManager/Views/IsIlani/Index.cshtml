@model List<jobmanager.Model.IsIlani>

<form method="get">
    <input type="text" name="searchString" placeholder="İş ilanı ara..." />
    <button class="btn btn-primary">Ara</button>
</form>

<br />

<a asp-action="Create" class="btn btn-success">Yeni İş İlanı</a>

<table class="table table-bordered mt-3">
    <tr>
        <th>Başlık</th>
        <th>Açıklama</th>
        <th>İşlemler</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Baslik</td>
            <td>@item.Aciklama</td>

            <td>
                <a asp-action="Edit"
                   asp-route-id="@item.IsIlaniId"
                   class="btn btn-warning">
                    Düzenle
                </a>

                <a asp-action="Delete"
                   asp-route-id="@item.IsIlaniId"
                   class="btn btn-danger">
                    Sil
                </a>
            </td>
        </tr>
    }
</table>